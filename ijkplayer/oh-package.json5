    "ijkplayer",
    "视频播放器"
  ],
  "tags": [
    "Media"
  ],
  "author": "yaoshining",
  "license": "LGPLv2.1 or later",
  "repository": "https://gitcode.com/yaoshining/ohos_ijkplayer",
